_TEST_SEPARATOR = "=" * 72
_SECTION_RULE = "-" * 72


def _print_section_banner(title: str) -> None:
  print(f"\n{_SECTION_RULE}\n{title}\n{_SECTION_RULE}\n")


def _tool_args_to_fenced_block(args: Any) -> str:
  """Format tool arguments for markdown (fenced block)."""
  if args is None:
    return ""
  if isinstance(args, str):
    s = args.strip()
    if not s:
      return ""
    try:
      parsed = json.loads(s)
      inner = json.dumps(parsed, indent=2, ensure_ascii=False)
      lang = "json"
    except Exception:
      inner = s
      lang = "text"
  else:
    inner = json.dumps(args, indent=2, ensure_ascii=False)
    lang = "json"
  return f"```{lang}\n{inner}\n```\n"


def _tool_call_name_and_args(tc: dict[str, Any]) -> tuple[str, Any]:
  name = tc.get("tool_name") or tc.get("name")
  fn = tc.get("function") if isinstance(tc.get("function"), dict) else {}
  if name is None and isinstance(fn, dict):
    name = fn.get("name")
  args = tc.get("args") if "args" in tc else tc.get("arguments")
  if args is None and isinstance(fn, dict):
    args = fn.get("arguments")
  return str(name or "(unknown_tool)"), args


def proposal_tool_calls_to_markdown(calls: list[Any]) -> str:
  """Render propose-run ``calls`` as ``# Round N`` + ``## Invoked tools`` (no token/latency metadata)."""
  if not isinstance(calls, list) or len(calls) == 0:
    return "_No LLM round-trips._\n"
  parts: list[str] = []
  for idx, turn in enumerate(calls, start=1):
    parts.append(f"# Round {idx}\n\n")
    if not isinstance(turn, dict):
      parts.append(f"- _(non-object round):_ `{type(turn).__name__}`\n\n")
      continue
    tcs = turn.get("tool_calls")
    if not isinstance(tcs, list) or not tcs:
      parts.append("_No tool calls this round._\n\n")
      continue
    parts.append("## Invoked tools\n\n")
    for tci, tc in enumerate(tcs, start=1):
      if not isinstance(tc, dict):
        parts.append(f"{tci}. _(invalid tool call entry)_\n\n")
        continue
      name_s, args = _tool_call_name_and_args(tc)
      parts.append(f"{tci}. **`{name_s}`**\n\n")
      fence = _tool_args_to_fenced_block(args)
      if fence:
        parts.append(fence)
      parts.append("\n")
  return "".join(parts).rstrip() + "\n"


def proposal_tool_calls_xml(calls: list[Any]) -> str:
  md = proposal_tool_calls_to_markdown(calls)
  return f"<PROPOSAL_TOOL_CALLS>\n\n{md.rstrip()}\n\n</PROPOSAL_TOOL_CALLS>\n"


def _render_rationalize_block(index: int, body: str) -> str:
  tag = f"RATIONALIZE_{index}"
  return f"<{tag}>\n\n{body.rstrip()}\n\n</{tag}>\n"


def build_rationalize_blocks(*, contexts: list[dict[str, Any]]) -> str:
  """``<RATIONALIZE_1>`` … ``<RATIONALIZE_N>`` (rationalize row traces omitted — Hermes grader shape)."""
  if not isinstance(contexts, list) or not contexts:
    raise ValueError("contexts must be a non-empty list")
  blocks: list[str] = []
  for i, ctx in enumerate(contexts, start=1):
    if not isinstance(ctx, dict):
      raise TypeError(f"contexts[{i - 1}] must be a dict")
    ra = (ctx.get("rationalize_agent_outcome") or "").strip()
    if not ra:
      raise ValueError(f"contexts[{i - 1}].rationalize_agent_outcome must be non-empty")
    blocks.append(_render_rationalize_block(i, ra))
  return "\n\n".join(blocks)


def calls_to_markdown(calls: list[Any]) -> str:
  """Alias for propose-run tool-call markdown (legacy name)."""
  return proposal_tool_calls_to_markdown(calls)


def bundle_checker_input(
  *,
  rationalize_agent_outcome: str,
  propose_agent_outcome: str,
  calls: list[Any],
) -> str:
  """Build grader bundle: ``<RATIONALIZE_1>``, ``<PROPOSAL>``, ``<PROPOSAL_TOOL_CALLS>``."""
  return build_propose_next_steps_grader_bundle(
    contexts=[{"rationalize_agent_outcome": rationalize_agent_outcome}],
    propose_agent_outcome=propose_agent_outcome,
    calls=calls,
  )


def build_propose_next_steps_grader_bundle(
  *,
  contexts: list[dict[str, Any]],
  propose_agent_outcome: str,
  calls: list[Any] | None = None,
) -> str:
  """Hermes-aligned checker input: ``<RATIONALIZE_N>`` …, ``<PROPOSAL>``, ``<PROPOSAL_TOOL_CALLS>``."""
  ra_block = build_rationalize_blocks(contexts=contexts)
  pa = (propose_agent_outcome or "").strip()
  if not pa:
    raise ValueError("propose_agent_outcome must be non-empty")
  if calls is not None and not isinstance(calls, list):
    raise TypeError("calls must be a list (use [] if the propose row has no tool invocations).")
  return (
    f"{ra_block}\n\n"
    f"<PROPOSAL>\n\n{pa}\n\n</PROPOSAL>\n\n"
    + proposal_tool_calls_xml(calls if isinstance(calls, list) else [])
  )


def bundle_checker_input_multi(
  *,
  contexts: list[dict[str, Any]],
  propose_agent_outcome: str,
  calls: list[Any],
) -> str:
  """
  Multi-context grader bundle: numbered ``<RATIONALIZE_N>`` blocks, then ``<PROPOSAL>``, ``<PROPOSAL_TOOL_CALLS>``.
  Each context dict: ``rationalize_agent_outcome`` (str). Optional ``calls`` (rationalize trace) is ignored.
  """
  return build_propose_next_steps_grader_bundle(
    contexts=contexts,
    propose_agent_outcome=propose_agent_outcome,
    calls=calls,
  )


